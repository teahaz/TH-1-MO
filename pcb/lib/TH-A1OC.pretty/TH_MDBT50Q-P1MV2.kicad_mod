			(thermal_gap 0.5)
			(thermal_bridge_width 0.5)
		)
		(polygon
			(pts
				(xy -3.25 -2.05) (xy 14.75 -2.05) (xy 14.75 4.3) (xy -3.25 4.3)
			)
		)
	)
	(embedded_fonts no)
	(model "${KIPRJMOD}/../../lib/3D_models/nrf52840_module.stp"
		(offset
			(xyz 0 0 0)
		)
		(scale
			(xyz 1 1 1)
		)
		(rotate
			(xyz -0 -0 90)
		)
	)
)
